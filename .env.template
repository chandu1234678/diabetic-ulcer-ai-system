# ========================================
# ENVIRONMENT CONFIGURATION TEMPLATE
# ========================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control!

# ========================================
# APPLICATION
# ========================================
ENVIRONMENT=development
DEBUG=False
APP_NAME=Diabetic Ulcer AI System

# ========================================
# SECURITY (REQUIRED)
# ========================================
# Generate secure keys using: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ========================================
# DATABASE
# ========================================
# Local development (SQLite)
DATABASE_URL=sqlite:///./medvision.db

# Production (PostgreSQL example)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ========================================
# FRONTEND
# ========================================
# Local development
FRONTEND_URL=http://localhost:3000

# Production (update after deploying to Vercel)
# FRONTEND_URL=https://your-app.vercel.app

# ========================================
# CORS ORIGINS
# ========================================
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000

# Production example:
# ALLOWED_ORIGINS=https://your-app.vercel.app,https://your-backend.onrender.com

# ========================================
# ML MODEL PATHS
# ========================================
# Relative to project root
CNN_MODEL_PATH=backend/models/best_dfu_model.pth
SEGMENTATION_MODEL_PATH=backend/models/segmentation_model.pth
MULTIMODAL_MODEL_PATH=backend/models/multimodal_model.pth

# ========================================
# CLOUDINARY (OPTIONAL)
# ========================================
# For cloud image storage - leave empty to use local storage
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ========================================
# EMAIL / SMTP (OPTIONAL)
# ========================================
# For password reset functionality
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@diabeticulcer.com
SMTP_FROM_NAME=Diabetic Ulcer AI System

# ========================================
# MONITORING (OPTIONAL)
# ========================================
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001

# ========================================
# MLFLOW (OPTIONAL)
# ========================================
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=diabetic-ulcer-detection

# ========================================
# EXPLAINABILITY
# ========================================
SHAP_BACKGROUND_SAMPLES=100
LIME_SAMPLES=1000
